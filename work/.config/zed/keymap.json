// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      // Put key bindings here if you want them to work in normal & visual mode.
      "space ,": "tab_switcher::ToggleAll",
      "space space": "file_finder::Toggle",
      "alt-x": "command_palette::Toggle",

      "space o t": "terminal_panel::ToggleFocus",
      "space o shift-t": "workspace::NewCenterTerminal",

      "shift-k" : "editor::Hover",
      "space c i": "editor::GoToImplementation",
      "space c t": "editor::GoToTypeDefinition",

      // copy paths
      // "space y f": "workspace::CopyPath", // copy absolute path (no line number support)
      "space y f": ["task::Spawn", { "task_label": "Copy path with line number" }], // copy absolute path with line number (hacky, spawns confirmation dialog)
      "space y F": "editor::CopyFileLocation", // copy relative path
      "space y ctrl-f" : "editor::CopyFileName"
    }
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "shift-y": ["workspace::SendKeystrokes", "y $"] // Use neovim's yank behavior: yank to end of line.
    }
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds"
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "g w": "vim::HelixJumpToWord"
    }
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "g x": "vim::Exchange"
    }
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      // Traditional Vim behavior
      "q": "vim::AnyQuotes",
      "b": "vim::AnyBrackets",

      // mini.ai plugin behavior
      "Q": "vim::MiniQuotes",
      "B": "vim::MiniBrackets"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
      "ctrl-e": "editor::MoveToEndOfLine"
    },
  }
]
