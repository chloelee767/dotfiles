#!/usr/bin/env sh

# From: https://jvns.ca/til/fzf-preview-git-commits/

set -eou pipefail

show_help() {
    cat << 'EOF'
Usage: jq-preview FILE
  Interactive jq query builder with fzf preview.

Examples:
  jq-preview data.json    # Interactively build jq query
EOF
}

while [ $# -gt 0 ]
do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

tmp_input=''
cleanup() {
    if [ -n "$tmp_input" ] && [ -f "$tmp_input" ]; then
        rm -f "$tmp_input"
    fi
}
trap cleanup EXIT

if [ $# -eq 1 ]; then
    input_file=$1
elif [ $# -eq 0 ] && [ ! -t 0 ]; then
    tmp_input=$(mktemp)
    input_file=$tmp_input
    cat > "$input_file"
else
    show_help
    exit 1
fi

fzf_out=$(printf '' | fzf --print-query \
  --expect=esc,ctrl-c,enter \
  --preview "jq -C {q} '$input_file' 2>&1" \
  --preview-window=up:80% \
  --query ".") || true

query=$(printf '%s' "$fzf_out" | sed -n '1p')
key=$(printf '%s' "$fzf_out" | sed -n '2p')

if [ -z "$query" ]; then
    exit 0
fi

echo "$query" >&2

if [ "$key" = "enter" ]; then
    jq "$query" "$input_file"
else
    tmp=$(mktemp /tmp/jq-output-XXXXXX.json)
    jq "$query" "$input_file" > "$tmp"
    echo "query output saved to $tmp" >&2
    # echo "$tmp"
fi
