# prevent nested ranger instances: https://wiki.archlinux.org/title/Ranger#PDF_file_preview
ranger() {
    if [ -z "$RANGER_LEVEL" ]; then
        /usr/bin/ranger "$@"
    else
        exit
    fi
}

# use yazi to cd into a directory
# press Q to change the directory, q to avoid changing directory
# https://yazi-rs.github.io/docs/quick-start#shell-wrapper
yz() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

# cd to the root of the current git project.
# This needs to be a function, not a script, because it needs to change the current shell's directory.
up() {
    # Find the top-level directory of the current git repository.
    # The '2>/dev/null' part suppresses the error message from git
    # if we are not currently inside a git repository.
    local git_root="$(git rev-parse --show-toplevel 2>/dev/null)"

    if [ -n "$git_root" ]; then
        cd "$git_root"
    else
        echo "Not inside a git repository." >&2
    fi
}

# cd to a git worktree
# This needs to be a function, not script, because they need to change the current shell's directory.
git-worktree-cd() {
    local target
    target=$(command _git-worktree-cd-helper "$@")
    if [ -n "$target" ]; then
        cd "$target"
    fi
}

git-worktree-cdm() {
    cd "$(dirname "$(git rev-parse --git-common-dir)")"
}

worktree() {
    local cmd="$1"
    shift
    case "$cmd" in
    cd) git-worktree-cd "$@" ;;
    cdm) git-worktree-cdm "$@" ;;
    add) git-worktree-add "$@" ;;
    remove) git-worktree-remove "$@" ;;
    *) git worktree "$cmd" "$@" ;;
    esac
}

