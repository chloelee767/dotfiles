#!/usr/bin/env bash

# Ensure we are inside a git repository
if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "Error: Not a git repository." >&2
    exit 1
fi

# 1. Get all worktrees (includes main and linked ones)
# 2. Use fzf to let the user select one
# 3. Extract just the absolute path from the selection
TARGET_DIR=$(git worktree list | fzf --height 40% --reverse --header "Select a worktree to cd into:" --query "$*" | awk '{print $1}')

# If the user cancels fzf, exit quietly
if [ -z "$TARGET_DIR" ]; then
    exit 0
fi

# Print the directory so the calling shell function can capture it
echo "$TARGET_DIR"
