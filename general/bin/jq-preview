#!/usr/bin/env sh

# From: https://jvns.ca/til/fzf-preview-git-commits/

set -eou pipefail

show_help() {
    cat << 'EOF'
Usage: jq-preview FILE
  Interactive jq query builder with fzf preview.

Examples:
  jq-preview data.json    # Interactively build jq query
EOF
}

while [ $# -gt 0 ]
do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

input_file=''
cleanup() {
    if [ -n "$input_file" ] && [ -f "$input_file" ]; then
        rm -f "$input_file"
    fi
}
trap cleanup EXIT

if [ $# -eq 1 ]; then
    input_file=$1
elif [ $# -eq 0 ] && [ ! -t 0 ]; then
    input_file=$(mktemp)
    cat > "$input_file"
else
    show_help
    exit 1
fi

printf '' | fzf --print-query \
  --preview "jq -C {q} '$input_file' 2>&1" \
  --preview-window=up:80% \
  --query "." \
  --bind 'esc:print-query+abort' \
  --bind 'ctrl-c:print-query+abort'
