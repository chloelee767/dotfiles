#!/usr/bin/env bash

show_help() {
    cat << 'EOF'
Usage: zellij-to-session [NAME]
  Attach to or create a zellij session. Works both inside and outside zellij.

  With no NAME, opens zellij without a named session (only valid outside zellij).
  With NAME, attaches to the named session or creates it if it doesn't exist.
  Inside zellij with NAME, switches to that session.

Options:
  -h, --help    Show this help message

Examples:
  zellij-to-session              # Open zellij (outside zellij only)
  zellij-to-session my-project   # Attach/create session "my-project"
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    show_help
    exit 0
fi
if [ -n "$ZELLIJ" ]; then
    if [ -z "$1" ]; then
        echo "Already inside zellij, use the keybindings to create a new session" >&2
        exit 1
    fi
    zellij action switch-session "$1"
else
    if [ -z "$1" ]; then
        zellij
    else
        zellij attach --create "$1"
    fi
fi
